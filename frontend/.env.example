# SuburbScout API (Phase 7 FastAPI gateway)
#
# Local dev (optional — Vite dev proxy defaults to http://127.0.0.1:8000):
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
# Production (Vercel): set in Project → Settings → Environment Variables
VITE_API_BASE_URL=https://your-backend-url

# Optional: POST /api/query timeout when using Foundry mode (milliseconds)
# VITE_FOUNDRY_TIMEOUT_MS=120000
