# SuburbScout AI — copy to .env and fill in your values.
# Never commit .env (it is gitignored).

# --- Microsoft Foundry (optional — chat_client tries Foundry before OpenAI) ---
FOUNDRY_PROJECT_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT

# --- Azure OpenAI (Phase 2: planner + answer + embeddings) ---
# Resource base URL only — no /openai/v1 suffix
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
# Chat deployment: NL → QueryPlan + grounded answer narration
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Embedding deployment: semantic_search on town profiles (local vector index)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=

# --- Query agent (default production path) ---
# LLM plans/explains; plan_executor ranks from suburbs.json (see docs/PHASE2_AZURE.md)
USE_LLM_QUERY_PLANNER=true
LLM_QUERY_PLANNER_MAX_REPAIR_ATTEMPTS=1
USE_LLM_QUERY_AGENT=true
USE_LLM_ANSWER=true
USE_LLM_ANSWER_VALIDATOR=true

# --- Google Maps (Distance Matrix — commute times) ---
GOOGLE_MAPS_API_KEY=

# --- Commute destination (all towns measured to this point) ---
COMMUTE_DESTINATION=South Station, Boston, MA

# --- API (Phase 2 Step 6) ---
# python scripts/run_api.py  →  http://127.0.0.1:8000

# --- Phase 7: Backend execution mode ---
# local = FastAPI runs local query_agent pipeline (default for dev)
# foundry = FastAPI proxies to deployed Foundry Hosted Agent (demo/cloud)
BACKEND_AGENT_MODE=local
# If foundry call fails, fall back to local pipeline (useful for live demos)
FALLBACK_TO_LOCAL=false

# Foundry Hosted Agent gateway (required when BACKEND_AGENT_MODE=foundry)
# Hosted Agents need a supported region project (e.g. eastus2, not eastus)
FOUNDRY_AGENT_NAME=suburbscout-hosted
# Leave empty to use the active agent version; pin e.g. 3 for a fixed demo
FOUNDRY_AGENT_VERSION=
# Optional full URL; if unset, built from FOUNDRY_PROJECT_ENDPOINT + agent name/version
FOUNDRY_AGENT_RESPONSES_ENDPOINT=

# CORS origins for Phase 8 React (comma-separated)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PostgreSQL (Phase 3A + 3C) ---
# docker compose up -d && python scripts/init_db.py && python scripts/seed_suburbs.py
# Supabase: paste connection string, then init_db + seed_suburbs
DATABASE_URL=postgresql://suburbscout:suburbscout_dev@localhost:5432/suburbscout
