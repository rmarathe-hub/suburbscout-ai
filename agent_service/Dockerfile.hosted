# Foundry Hosted Agent image (Responses protocol, port 8088, linux/amd64).
#
# Build:
#   docker build --platform linux/amd64 -f Dockerfile.hosted -t suburbscout-hosted:v1 .
#
# Or push via ACR cloud build (no local Docker on ARM):
#   az acr build --registry <acr> --image suburbscout-hosted:v1 --platform linux/amd64 -f Dockerfile.hosted .

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-hosted.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-hosted.txt

COPY app/ ./app/
COPY alembic/ ./alembic/
COPY alembic.ini .

EXPOSE 8088

CMD ["python", "-m", "app.hosted_main"]
